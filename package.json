{
  "name": "meow-memorizing",
  "description": "记单词的小插件",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "license": "LGPL-3.0-only",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "wasm": "bash scripts/build-wasm.sh && bun run scripts/inline-wasm.ts",
    "build": "mkdir -p target && rustc --edition=2021 scripts/package-extensions.rs -o target/package-extensions && target/package-extensions",
    "build:chrome": "bun run wasm && wxt zip -b chrome && bun run src/copy.ts",
    "build:firefox": "bun run wasm && wxt zip -b firefox --sources",
    "zip": "bun run build:chrome",
    "zip:firefox": "bun run build:firefox",
    "docs:gif": "bun run build && bun run scripts/update-readme-gif.ts",
    "compile": "tsc --noEmit",
    "check:rust": "cargo check -p wasm-matcher --target wasm32-unknown-unknown",
    "lint:rust": "cargo fmt --all --check && cargo clippy -p wasm-matcher --target wasm32-unknown-unknown -- -D warnings",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare",
    "prepare": "husky"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "@webext-core/messaging": "^3.0.2",
    "@webext-core/storage": "^1.2.1",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-react": "^1.2.2",
    "antd": "^6.4.3",
    "autoprefixer": "^10.5.0",
    "axios": "^1.17.0",
    "classnames": "^2.5.1",
    "fs-extra": "^11.3.5",
    "husky": "^9.1.7",
    "lie": "^3.3.0",
    "lint-staged": "^17.0.7",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wxt": "^0.21.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome format --write",
      "biome lint --fix",
      "git add"
    ],
    "bun.lockb": [
      "bun install",
      "git add bun.lockb"
    ],
    "package.json": [
      "bun install",
      "git add bun.lockb"
    ]
  }
}
